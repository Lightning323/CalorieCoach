<% const totalCalories=todayFoods.reduce((sum, f)=> sum + (f.foodItem ? f.foodItem.calories * f.quantity : 0), 0);
  const totalProtein = todayFoods.reduce((sum, f) => sum + (f.foodItem ? (f.foodItem.protein ?? 0) * f.quantity : 0),
  0);
  const totalCarbs = todayFoods.reduce((sum, f) => sum + (f.foodItem ? (f.foodItem.carbs ?? 0) * f.quantity : 0), 0);
  const totalFat = todayFoods.reduce((sum, f) => sum + (f.foodItem ? (f.foodItem.fat ?? 0) * f.quantity : 0), 0);

    function calorieGoal(){
        return maintenanceCalories + calorieOffset;
    }

  const percent = Math.min((totalCalories / calorieGoal()) * 100, 100);
  const calorieGoalTolerance = 20;
  const overGoal = totalCalories > calorieGoal()+calorieGoalTolerance;

  const proteinProgress = proteinGoal > 0 ? Math.min((totalProtein / proteinGoal) * 100, 100) : 0;
  const proteinGoalReached = totalProtein >= proteinGoal;





  //Get last N days sorted by date from most recent to least recent
  const sortedDates = Object.keys(foodHistory).sort((a,b)=> new Date(a).getTime() - new Date(b).getTime());
  const today = new Date().setUTCHours(0,0,0,0);
  const rangeEnd = today; //Our end date (today)
  const historyTimeWindowDays = 30;
  const rangeStart = new Date(rangeEnd);//Our start date (N days ago)
  rangeStart.setUTCDate(rangeStart.getUTCDate() - historyTimeWindowDays);


  //Get sorted dates, but only keep the ones that are between the start and end dates
  const lastNDates = sortedDates.filter(dateStr => {
  const d = new Date(dateStr).setUTCHours(0,0,0,0);
  return d >= rangeStart && d <= rangeEnd; }).sort((a,b)=> new Date(a).getTime() - new Date(b).getTime());

    const totalCaloriesInRange = lastNDates.reduce((sum, date) => sum + (foodHistory[date].calories ?? 0), 0);
    const totalProteinInRange = lastNDates.reduce((sum, date) => sum + (foodHistory[date].protein ?? 0), 0);
    const totalCarbsInRange = lastNDates.reduce((sum, date) => sum + (foodHistory[date].carbs ?? 0), 0);
    const totalFatInRange = lastNDates.reduce((sum, date) => sum + (foodHistory[date].fat ?? 0), 0);

    const caloriesDelta = totalCaloriesInRange - (calorieGoal() * lastNDates.length);
    const proteinDelta = totalProteinInRange - (proteinGoal * lastNDates.length);


     %>  
         <h2 class="mb-3">Consumption</h2>
<div class="card p-3 shadow-sm mb-4">

            <div>

              <div class="d-flex justify-content-between align-items-center mb-2">
                <h5 class="mb-0">
                  <strong>
                    <%= Math.round(totalCalories) %> / <%= Math.round(calorieGoal()) %> kcal
                  </strong>
                  <span class="text-muted" style="font-size: 0.8em;text-wrap:nowrap;">
 (<%= calorieOffset > 0 ? "+" : "" %><%= Math.round(calorieOffset) %> of <%= maintenanceCalories %> kcal)
                  </span>
                  
                </h5>
                <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#goalModal">
                  Change Goal
                </button>
              </div>

              <div class="progress mb-3" style="height: 10px;">
                <div class="progress-bar <%= overGoal ? 'bg-danger' : 'bg-success' %>" role="progressbar"
                  style="width: <%= (totalCalories / calorieGoal()) * 100 %>%">
                </div>
              </div>

              <% if (overGoal) { %>
                <div class="text-danger mt-1 text-center">
                  <i class="fa-solid fa-triangle-exclamation"></i><strong>
                    <%= Math.round(totalCalories-calorieGoal()) %>
                  </strong> kcal over your limit
                </div>
                <% } else { %>
                  <div class="text-success mt-1 text-center">
                    <i class="fa fa-fire"></i> <strong>
                      <%= Math.max(0, Math.round(calorieGoal() - totalCalories)) %>
                    </strong> kcal remaining
                  </div>
                  <% } %>

                    <hr>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                       <h5 class="mb-0">
                  <strong>

                    
                    <%= Math.round(totalProtein) %> / <%= Math.round(proteinGoal) %>g protein
                  </strong>
                </h5>
                      <small class="text-muted">
                    <% if (proteinGoalReached) { %> Protein goal reached
                      <% } else { %><%= Math.round(proteinGoal - totalProtein) %>g</strong> to go
                      <% } %>
                      </small>
                    </div>

                    <div class="progress" style="height: 10px;">
                      <div class="progress-bar <%= proteinGoalReached ? 'bg-info' : 'bg-primary' %>" role="progressbar" style="width: <%= proteinProgress %>%">
                      </div>
                    </div>

             

            </div>

            <!-- History toggle -->
            <div data-bs-toggle="collapse" data-bs-target="#historyDiv" id="consumptionToggleable">

              <div style="text-align: center; margin-top: 10px;" data-bs-toggle="collapse" data-bs-target="#historyDiv"
                aria-expanded="false" id="historyToggle">
                <i class="fa fa-chevron-down"></i>
              </div>
            </div>

          <!-- History dropdown -->
            <div class="collapse mt-3" id="historyDiv">
              <div>
                <h5 class="mb-3"><i class="fa fa-history"></i> History</h5>
                <% if (foodHistory && Object.keys(foodHistory).length> 0) { %>
                  <% if (lastNDates.length> 0) { %>
                    <div class="small mb-3">
                      <%
                        const avgDailyTotalCalories=Math.round(totalCaloriesInRange / lastNDates.length);
                        const avgDailyTotalProtein=Math.round(totalProteinInRange / lastNDates.length);
                        const avgDailyTotalCarbs=Math.round(totalCarbsInRange / lastNDates.length);
                        const avgDailyTotalFat=Math.round(totalFatInRange / lastNDates.length);
                        %>
                        Daily average over <%= historyTimeWindowDays %> days:
                        <span class="text-nowrap <%= avgDailyTotalCalories > calorieGoal() + calorieGoalTolerance ? 'text-danger' : 'text-success' %>">
                          <strong><%= avgDailyTotalCalories %> kcal</strong>
                        </span>
                        <span class="text-nowrap <%= avgDailyTotalProtein < proteinGoal ? 'text-danger' : 'text-success' %>">
                          <strong><%= avgDailyTotalProtein %>g</strong> protein
                        </span>
                        <span class="text-muted text-nowrap">
                          <strong><%= avgDailyTotalCarbs %>g</strong> carbs, <strong><%= avgDailyTotalFat %>g</strong> fat
                        </span>
                    </div>
                    <% } %>

                      <ul class="nav nav-tabs" id="myTab" role="tablist">
                        <li class="nav-item" role="presentation">
                          <button class="nav-link active" id="home-tab" data-bs-toggle="tab" data-bs-target="#home"
                            type="button" role="tab">Weekly average</button>
                        </li>
                        <li class="nav-item" role="presentation">
                          <button class="nav-link" id="profile-tab" data-bs-toggle="tab" data-bs-target="#profile"
                            type="button" role="tab">Daily totals</button>
                        </li>
                      </ul>

                      <!--
    Weekly and daily consumption
    -->
                      <div class="tab-content" id="myTabContent">
                        <div class="tab-pane fade show active" id="home" role="tabpanel">
                          <!-- Weekly -->
                          <ul class="list-group">
                            <% let weeklyTotal=[]; %>
                              <% let currentTimestamp=new Date().setUTCHours(0, 0, 0, 0); let i=0; for (let
                                date=currentTimestamp; date>= rangeStart; date -= 1000 * 60 * 60 * 24) {
                                const dateString = new Date(date).toISOString().split('T')[0];

                                if (foodHistory[dateString]) {
                                weeklyTotal.push(foodHistory[dateString]);
                                }
                                //TODO: Should we count today on the weekly average?
                                else if(date === today && totalCalories >= calorieGoal()){
                                weeklyTotal.push({calories: totalCalories, protein: totalProtein, carbs: totalCarbs,
                                fat: totalFat});
                                }

                                if( i>0 && i % 7 === 0) {
                                //We take what we do have and average it
                                let total = weeklyTotal.length;
                                if(total == 0) continue;

                                const totals = weeklyTotal.reduce((sum, item) => {
                                sum.calories += item.calories ?? 0;
                                sum.protein += item.protein ?? 0;
                                sum.carbs += item.carbs ?? 0;
                                sum.fat += item.fat ?? 0;
                                return sum;
                                }, {
                                calories: 0,
                                protein: 0,
                                carbs: 0,
                                fat: 0
                                });
                                // console.log(totals.calories+" total calories consumed on "+total+" days");
                                const calories = totals.calories / total;
                                const protein = totals.protein / total;
                                const carbs = totals.carbs / total;
                                const fat = totals.fat / total;
                                weeklyTotal = [];


                                const today = new Date().setUTCHours(0,0,0,0);
                                const msPerWeek = 1000 * 60 * 60 * 24 * 7;
                                const weeksAgo = Math.floor((today - date) / msPerWeek) - 1;

                                let weeksAgoStr = `${weeksAgo} weeks ago`
                                if (weeksAgo < 1) { weeksAgoStr="This Week" }
                                else if(weeksAgo < 2) {
                                  weeksAgoStr="Last Week" } 
                                  %>
                                  <li class="list-group-item">
                                    <div class="d-flex justify-content-between">
                                      <span>
                                        <%= weeksAgoStr %>
                                      </span>
                                      <strong
                                        class="text-<%= calories > calorieGoal()+calorieGoalTolerance ? 'danger' : 'success' %>">
                                        <%= Math.round(calories) %> avg kcal
                                      </strong>
                                    </div>
                                    <div class="small text-muted">
                                      <span class="text-nowrap">Protein: <strong><%= Math.round(protein) %>g</strong></span>
                                      • <span class="text-nowrap">Carbs: <strong><%= Math.round(carbs) %>g</strong> </span>
                                      • <span class="text-nowrap">Fat: <strong><%= Math.round(fat) %>g</strong></span>
                                    </div>
                                  </li>
                                  <% } i+=1; } %>
                          </ul>
                        </div>
                        <div class="tab-pane fade" id="profile" role="tabpanel">
                          <!-- Daily -->
                          <ul class="list-group">
                            <% for (let i=sortedDates.length - 1; i>= 0; i-=1) {
                              const date = sortedDates[i];
                              const totals = foodHistory[date];
                              const calories = totals?.calories ?? 0;
                              const protein = totals?.protein ?? 0;
                              const carbs = totals?.carbs ?? 0;
                              const fat = totals?.fat ?? 0;
                              const d = new Date(date);
                              const daysAgo = Math.round((new Date().setUTCHours(0,0,0,0) - d.getTime()) /
                              (1000*60*60*24));
                              %>
                              <li class="list-group-item">
                                <div class="d-flex justify-content-between">
                                  <span>
                                    <%= daysAgo<=1 ? "Yesterday" : `${daysAgo} days ago` %>
                                  </span>
                                  <strong
                                    class="text-<%= calories > calorieGoal()+calorieGoalTolerance ? 'danger' : 'success' %>">
                                    <%= Math.round(calories) %> kcal
                                  </strong>
                                </div>
                                <div class="small text-muted">
                                  Protein: <strong>
                                    <%= Math.round(protein) %>g
                                  </strong> • Carbs: <strong>
                                    <%= Math.round(carbs) %>g
                                  </strong> • Fat: <strong>
                                    <%= Math.round(fat) %>g
                                  </strong>
                                </div>
                              </li>
                              <% } %>
                          </ul>
                        </div>
                      </div>



                      <% } else { %>
                        <div class="text-muted text-center">
                          No history yet...
                        </div>
                        <% } %>
              </div>
            </div>



          </div>